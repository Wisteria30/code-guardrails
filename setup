#!/usr/bin/env bash
set -euo pipefail

RED='\033[91m'
GREEN='\033[92m'
YELLOW='\033[93m'
RESET='\033[0m'

ISSUES=0
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

check_version() {
  local tool="$1"
  local current="$2"
  local minimum="$3"
  local cur_major cur_minor min_major min_minor
  cur_major=$(echo "$current" | cut -d. -f1)
  cur_minor=$(echo "$current" | cut -d. -f2)
  min_major=$(echo "$minimum" | cut -d. -f1)
  min_minor=$(echo "$minimum" | cut -d. -f2)
  if [ "$cur_major" -gt "$min_major" ] 2>/dev/null || \
     { [ "$cur_major" -eq "$min_major" ] 2>/dev/null && [ "$cur_minor" -ge "$min_minor" ] 2>/dev/null; }; then
    echo -e "  ${GREEN}version ${current} >= ${minimum}${RESET}"
    return 0
  else
    echo -e "  ${RED}version ${current} < ${minimum} (need ${minimum}+)${RESET}"
    return 1
  fi
}

install_tool() {
  local tool="$1"
  local brew_pkg="$2"
  local npm_pkg="$3"

  echo -e "${YELLOW}MISSING${RESET} $tool — installing..."

  # Try brew first (macOS/Linux)
  if command -v brew &>/dev/null; then
    brew install "$brew_pkg" 2>/dev/null && echo -e "  ${GREEN}installed via brew${RESET}" && return 0
  fi

  # Try npm
  if command -v npm &>/dev/null; then
    npm install -g "$npm_pkg" 2>/dev/null && echo -e "  ${GREEN}installed via npm${RESET}" && return 0
  fi

  # Try cargo
  if command -v cargo &>/dev/null; then
    cargo install "$brew_pkg" --locked 2>/dev/null && echo -e "  ${GREEN}installed via cargo${RESET}" && return 0
  fi

  echo -e "  ${RED}failed${RESET} — install manually: brew install $brew_pkg"
  return 1
}

ensure_tool() {
  local cmd="$1"
  local brew_pkg="$2"
  local npm_pkg="$3"
  local min_version="$4"
  local version_cmd="$5"

  if command -v "$cmd" &>/dev/null; then
    echo -e "${GREEN}OK${RESET} $cmd ($(command -v "$cmd"))"
    local ver
    ver=$(eval "$version_cmd" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)
    check_version "$cmd" "$ver" "$min_version" || ISSUES=1
  else
    install_tool "$cmd" "$brew_pkg" "$npm_pkg" || ISSUES=1
    # Re-check after install
    if command -v "$cmd" &>/dev/null; then
      echo -e "${GREEN}OK${RESET} $cmd ($(command -v "$cmd"))"
      local ver
      ver=$(eval "$version_cmd" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)
      check_version "$cmd" "$ver" "$min_version" || ISSUES=1
    fi
  fi
}

echo "code-guardrails setup"
echo "====================="
echo ""

# --- Python 3.12+ ---
if command -v python3 &>/dev/null; then
  echo -e "${GREEN}OK${RESET} python3 ($(command -v python3))"
  PY_VER=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
  check_version "python3" "$PY_VER" "3.12" || ISSUES=1
else
  echo -e "${RED}MISSING${RESET} python3 — install from https://www.python.org/downloads/"
  ISSUES=1
fi

# --- ast-grep 0.14+ ---
ensure_tool "ast-grep" "ast-grep" "@ast-grep/cli" "0.14" "ast-grep --version"

# --- ripgrep 14.0+ ---
ensure_tool "rg" "ripgrep" "ripgrep" "14.0" "rg --version"

# --- PyYAML 6.0+ ---
echo ""
if python3 -c "import yaml" 2>/dev/null; then
  echo -e "${GREEN}OK${RESET} PyYAML"
  YAML_VER=$(python3 -c "import yaml; print(yaml.__version__)" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)
  check_version "PyYAML" "$YAML_VER" "6.0" || ISSUES=1
else
  echo -e "${YELLOW}MISSING${RESET} PyYAML — installing..."
  python3 -m pip install --quiet "PyYAML>=6.0" && echo -e "  ${GREEN}installed${RESET}" || { echo -e "  ${RED}failed${RESET}"; ISSUES=1; }
fi

echo ""
if [ "$ISSUES" -ne 0 ]; then
  echo -e "${RED}Some dependencies are missing or outdated. Fix them and re-run setup.${RESET}"
  exit 1
fi

# --- Pre-compile .pyc for fast first run ---
python3 -m compileall -q "$SCRIPT_DIR/check_policy.py" 2>/dev/null && \
  echo -e "${GREEN}OK${RESET} bytecode pre-compiled" || true

echo -e "${GREEN}All dependencies OK. code-guardrails is ready.${RESET}"
