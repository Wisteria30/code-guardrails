#!/usr/bin/env bash
set -euo pipefail

RED='\033[91m'
GREEN='\033[92m'
YELLOW='\033[93m'
RESET='\033[0m'

ISSUES=0
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

check_version() {
  local tool="$1"
  local current="$2"
  local minimum="$3"
  local cur_major cur_minor min_major min_minor
  cur_major=$(echo "$current" | cut -d. -f1)
  cur_minor=$(echo "$current" | cut -d. -f2)
  min_major=$(echo "$minimum" | cut -d. -f1)
  min_minor=$(echo "$minimum" | cut -d. -f2)
  if [ "$cur_major" -gt "$min_major" ] 2>/dev/null || \
     { [ "$cur_major" -eq "$min_major" ] 2>/dev/null && [ "$cur_minor" -ge "$min_minor" ] 2>/dev/null; }; then
    echo -e "  ${GREEN}version ${current} >= ${minimum}${RESET}"
    return 0
  else
    echo -e "  ${RED}version ${current} < ${minimum} (need ${minimum}+)${RESET}"
    return 1
  fi
}

install_tool() {
  local tool="$1"
  local brew_pkg="$2"
  local npm_pkg="$3"

  echo -e "${YELLOW}MISSING${RESET} $tool — installing..."

  # Try brew first (macOS/Linux)
  if command -v brew &>/dev/null; then
    brew install "$brew_pkg" 2>/dev/null && echo -e "  ${GREEN}installed via brew${RESET}" && return 0
  fi

  # Try npm
  if command -v npm &>/dev/null; then
    npm install -g "$npm_pkg" 2>/dev/null && echo -e "  ${GREEN}installed via npm${RESET}" && return 0
  fi

  # Try cargo
  if command -v cargo &>/dev/null; then
    cargo install "$brew_pkg" --locked 2>/dev/null && echo -e "  ${GREEN}installed via cargo${RESET}" && return 0
  fi

  echo -e "  ${RED}failed${RESET} — install manually: brew install $brew_pkg"
  return 1
}

ensure_tool() {
  local cmd="$1"
  local brew_pkg="$2"
  local npm_pkg="$3"
  local min_version="$4"
  local version_cmd="$5"

  if command -v "$cmd" &>/dev/null; then
    echo -e "${GREEN}OK${RESET} $cmd ($(command -v "$cmd"))"
    local ver
    ver=$(eval "$version_cmd" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)
    check_version "$cmd" "$ver" "$min_version" || ISSUES=1
  else
    install_tool "$cmd" "$brew_pkg" "$npm_pkg" || ISSUES=1
    # Re-check after install
    if command -v "$cmd" &>/dev/null; then
      echo -e "${GREEN}OK${RESET} $cmd ($(command -v "$cmd"))"
      local ver
      ver=$(eval "$version_cmd" 2>/dev/null | grep -oE '[0-9]+\.[0-9]+' | head -1)
      check_version "$cmd" "$ver" "$min_version" || ISSUES=1
    fi
  fi
}

echo "code-guardrails setup"
echo "====================="
echo ""

# --- ast-grep 0.14+ ---
ensure_tool "ast-grep" "ast-grep" "@ast-grep/cli" "0.14" "ast-grep --version"

# --- ripgrep 14.0+ ---
ensure_tool "rg" "ripgrep" "ripgrep" "14.0" "rg --version"

echo ""
if [ "$ISSUES" -ne 0 ]; then
  echo -e "${RED}Some dependencies are missing or outdated. Fix them and re-run setup.${RESET}"
  exit 1
fi

# --- Rust toolchain (optional — engine built on first use if missing) ---
if command -v cargo &>/dev/null && command -v rustc &>/dev/null; then
  echo -e "${GREEN}OK${RESET} cargo ($(command -v cargo))"
  mkdir -p "$SCRIPT_DIR/bin"
  cargo build --manifest-path "$SCRIPT_DIR/Cargo.toml" --release && \
    cp "$SCRIPT_DIR/target/release/code-guardrails-engine" "$SCRIPT_DIR/bin/code-guardrails-engine" && \
    echo -e "${GREEN}OK${RESET} Rust engine built" || \
    echo -e "${YELLOW}WARN${RESET} Rust build failed — engine will be built on first use"
else
  echo -e "${YELLOW}SKIP${RESET} Rust toolchain not found — engine will be built on first use"
  echo -e "  When you edit a file, Claude Code will prompt you to install Rust via rustup."
fi

echo ""
echo -e "${GREEN}Setup complete. code-guardrails is ready.${RESET}"
